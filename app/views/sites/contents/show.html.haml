= content_for_site_page_title @site, 'Content Overview'
.sub-nav-heading{ class: ("--is-inactive" if @site&.active? == false) }
  %h2 Content Overview
  .action-bar
    %ul

= render_flash_message
%ul.content
  %li.content-item.domains
    = link_to site_domains_path(@site) do
      %i.fa.fa-globe-lightblue.fa-4x
      %div.name Domains
  %li.content-item
    = link_to site_collections_path(@site) do
      %span.no-icon Collections
  - if @site.gets_i14y_results
    %li.content-item
      = link_to site_i14y_drawers_path(@site) do
        %span.no-icon i14y Drawers
  %li.content-item
    = link_to site_best_bets_texts_path(@site) do
      %span.no-icon Best Bets: Text
  %li.content-item
    = link_to site_best_bets_graphics_path(@site) do
      %span.no-icon Best Bets: Graphics
  %li.content-item.routed-queries
    = link_to site_routed_queries_path(@site) do
      %span.no-icon Routed Queries

